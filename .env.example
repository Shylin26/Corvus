# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
TOPIC_METRICS=corvus.metrics
TOPIC_ANOMALY=corvus.anomaly
TOPIC_DIAGNOSIS=corvus.diagnosis
TOPIC_PLAN=corvus.plan
TOPIC_ACTION=corvus.action
TOPIC_RESULT=corvus.result

# Postgres
DATABASE_URL=postgresql+asyncpg://corvus:corvus@localhost:5432/corvus

# Redis
REDIS_URL=redis://localhost:6379

# Gateway
GATEWAY_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Settings
ENV=development
LOG_LEVEL=INFO
